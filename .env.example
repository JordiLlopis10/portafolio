# URL pública del sitio (usada para SEO: canonical, sitemap, Open Graph).
# En Vercel, configúrala como variable de entorno del proyecto.
NEXT_PUBLIC_SITE_URL=https://jordillopis.es

# Envío real del formulario de contacto (Formspree o servicio compatible).
# 1. Crea una cuenta gratuita en https://formspree.io con tu email
#    (llopisgodinojordi@gmail.com) — plan gratuito: 50 mensajes/mes.
# 2. Crea un formulario y copia su endpoint (https://formspree.io/f/XXXXXXXX).
# 3. Pega el endpoint aquí y en las variables de entorno de Vercel. Redeploy.
# Sin esta variable, el formulario usa mailto: (abre el cliente de correo
# del visitante) como respaldo.
# NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/XXXXXXXX

# Opcional: token personal de GitHub (scope: public_repo o ninguno).
# Aumenta el límite de peticiones a la API de GitHub de 60/h a 5000/h.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
